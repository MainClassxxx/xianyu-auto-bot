# 环境变量配置示例
# 复制此文件为 .env 并填入真实配置

# ============ 闲鱼配置 ============
# 闲鱼 Cookie (从浏览器 F12 Network 中获取)
XIANFU_COOKIE=your_cookie_here

# 设备 ID (可选，用于多账号)
XIANFU_DEVICE_ID=device_001

# ============ 数据库配置 ============
DATABASE_URL=sqlite:///data/xianyu_bot.db

# ============ 通知配置 ============
# 飞书 Webhook
FEISHU_WEBHOOK=
# Telegram Bot Token
TELEGRAM_BOT_TOKEN=
# 企业微信 Webhook
WECHAT_WORK_WEBHOOK=

# ============ AI 配置 (可选) ============
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ============ OCR 配置 (电影票识别) ============
# 百度 OCR (可选)
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# ============ 服务配置 ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
DEBUG=false

# ============ 自动化配置 ============
# 自动发货开关
AUTO_DELIVERY_ENABLED=true
# 自动改价开关
AUTO_PRICE_UPDATE_ENABLED=true
# 自动买票开关
AUTO_BUY_TICKET_ENABLED=true
# 截图检测开关
SCREENSHOT_DETECTION_ENABLED=true

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FILE=data/bot.log
